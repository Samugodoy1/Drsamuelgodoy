# URL da API central (obrigatório em produção)
VITE_API_URL=https://api.odontohub.app.br

# Microsoft Clarity — ID do projeto (obter em https://clarity.microsoft.com)
VITE_CLARITY_PROJECT_ID=

# Login com Google — Client ID OAuth 2.0 (Web) do Google Cloud Console
# Deve ser o MESMO client ID configurado no backend (GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
