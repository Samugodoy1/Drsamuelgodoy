# OdontoManager Pro - Variáveis de Ambiente

# Chave secreta para o JWT
JWT_SECRET="sua_chave_secreta_aqui"

# Configurações do Banco de Dados (Para produção, use PostgreSQL)
# No ambiente de desenvolvimento, usaremos SQLite via better-sqlite3
DATABASE_URL="file:./dev.db"

# Configurações de Cloud Storage (Exemplo)
